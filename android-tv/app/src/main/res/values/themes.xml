<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.Leanback" parent="Theme.Leanback.Browse">
        <item name="colorPrimary">#667eea</item>
        <item name="colorPrimaryDark">#764ba2</item>
        <item name="colorAccent">#4facfe</item>
    </style>

    <!-- Playback theme -->
    <style name="Theme.Playback" parent="Theme.Leanback">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Settings theme -->
    <style name="Theme.Settings" parent="Theme.Leanback.GuidedStep">
        <item name="colorPrimary">#667eea</item>
    </style>
</resources>
